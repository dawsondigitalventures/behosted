---
import Layout from "../../layouts/Article.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<Layout title="Blog | Be Hosted" description="Insights, ideas and inspiration from the Be Hosted team.">
  <main class="page__wrapper">
    <article class="post">
      <header class="post__header">
        <h1 class="heading">Blog</h1>
      </header>

      {posts.length === 0 && (
        <p>No posts yet — check back soon.</p>
      )}

      <ul class="blog-list">
        {posts.map((post) => (
          <li class="blog-list__item">
            <a href={`/blog/${post.id}/`}>
              <h2 class="blog-list__title">{post.data.title}</h2>
            </a>
            <p class="blog-list__date">
              {post.data.publishDate.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}
            </p>
            <p class="blog-list__description">{post.data.description}</p>
          </li>
        ))}
      </ul>
    </article>
  </main>
</Layout>
