---
import IndexPage from "../../layouts/IndexPage.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<IndexPage
  title="Journal | Be Hosted"
  description="Insights, ideas and inspiration from the Behosted team."
  heading="Journal"
>
  {posts.length === 0 && <p>No posts yet — check back soon.</p>}
  <ul class="index-list">
    {posts.map((post) => (
      <li class="index-card">
        <div class="index-card__content">
          <h2 class="index-card__title">{post.data.title}</h2>
          <p class="index-card__date">
            {post.data.publishDate.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}
          </p>
          <p class="index-card__description">{post.data.description}</p>
          <a class="link" href={`/blog/${post.id}/`}>Read the post &#x2192;</a>
        </div>
      </li>
    ))}
  </ul>
</IndexPage>
