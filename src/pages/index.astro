---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const featured = (await getCollection("case-studies", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 2);

const latestPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<Layout
  title="We Are Behosted | Tablescaping & Social Content Creation"
  description="From styled events and tablescaping to social-first content creation, BeHosted helps brands stand out with 10 years of combined marketing expertise."
>	
	<main>
		<section id="hero">
			<!--Insert hero section-->
			<div class="hero-text">
