		<!-- ═══════════════════════════════════════════════════
		     JOURNAL — new section
		     NEW: no equivalent in original index.astro.
		     Uses the `latestPosts` collection query from the
		     frontmatter above. If you don't have a blog collection
		     yet, replace the {latestPosts.map(...)} block with
		     three static <a class="journal__card"> elements using
		     placeholder content.
		     ═══════════════════════════════════════════════════ -->
		<section class="landing-section journal-section" id="journal">
			<div class="journal__header">
				<div>
					<p class="eyebrow">The Behosted edit</p>
					<h2 class="heading journal__heading">From the <em>journal</em></h2>
				</div>
				<a href="/blog/" class="section-link">All posts →</a>
			</div>
			<div class="journal__grid">
				{latestPosts.map((post, i) => (
					<a href={`/blog/${post.id}/`} class={`journal__card reveal${i > 0 ? ` reveal--delay-${i}` : ''}`}>
						{post.data.heroImage && (
							<img
								src={post.data.heroImage}
								alt={post.data.title}
								class="journal__card-img"
								loading="lazy"
							/>
						)}
						<div class="journal__card-meta">
							<span class="journal__card-date">
								{post.data.publishDate.toLocaleDateString('en-GB', {
									day: 'numeric',
									month: 'short',
									year: 'numeric'
								})}
							</span>
						</div>
						<h3 class="journal__card-title">{post.data.title}</h3>
						<p class="journal__card-excerpt">{post.data.description}</p>
						<span class="journal__card-cta">Read more →</span>
					</a>
				))}
			</div>
		</section>
 
		<!-- ═══════════════════════════════════════════════════
		     CTA
		     CHANGED: small centred box replaced with full-width
		     section. #cta-container removed. New .cta-section
		     classes styled in design-overrides.css.
		     ═══════════════════════════════════════════════════ -->
		<section class="landing-section cta-section" id="cta">
			<p class="eyebrow cta-section__eyebrow">Let's create together</p>
			<h2 class="cta-section__heading">
				Ready to create something <em>beautiful?</em>
			</h2>
			<p class="cta-section__sub">
				Whether you need content that converts or a table that wows,
				we'd love to hear from you.
			</p>
			<a
				href="https://docs.google.com/forms/d/e/1FAIpQLSeo4LEToHuBtsB65ZMBN8lZC6Y_CBEOvMHgDi5xAZGMaWgpIg/viewform?usp=header"
				class="cta-section__button"
				target="_blank"
			>
				Yes, absolutely
			</a>
		</section>
 
	</main>
</Layout>

<script>
	// ── Mobile nav drawer ─────────────────────────────────────
	// NEW — pairs with .nav__drawer markup above and the
	// hamburger button in your Layout.astro nav.
	// Add id="navToggle" to your existing hamburger button.
	const navToggle   = document.getElementById('navToggle');
	const navDrawer   = document.getElementById('navDrawer');
	const navBackdrop = document.getElementById('navBackdrop');
	const navClose    = document.getElementById('navClose');
 
	function openNav() {
		navDrawer?.classList.add('is-open');
		navBackdrop?.classList.add('is-visible');
		navToggle?.setAttribute('aria-expanded', 'true');
		document.body.style.overflow = 'hidden';
	}
 
	function closeNav() {
		navDrawer?.classList.remove('is-open');
		navBackdrop?.classList.remove('is-visible');
		navToggle?.setAttribute('aria-expanded', 'false');
		document.body.style.overflow = '';
	}
 
	navToggle?.addEventListener('click', openNav);
	navClose?.addEventListener('click', closeNav);
	navBackdrop?.addEventListener('click', closeNav);
	navDrawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));
 
	// ── Highlight underline animation ──────────────────────────
	// Unchanged from original — triggers .animate on .highlight
	// elements as they enter the viewport.
	const highlights = document.querySelectorAll('.highlight');
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('animate');
				observer.unobserve(entry.target);
			}
		});
	}, { threshold: 0.5 });
	highlights.forEach(el => observer.observe(el));
 
	// ── Scroll reveal ──────────────────────────────────────────
	// NEW — add class="reveal" to any element you want to fade
	// up on scroll. Pairs with .reveal / .reveal.in-view in
	// design-overrides.css utilities section.
	const revealEls = document.querySelectorAll('.reveal');
	const revealObserver = new IntersectionObserver((entries) => {
		entries.forEach(e => {
			if (e.isIntersecting) {
				e.target.classList.add('in-view');
				revealObserver.unobserve(e.target);
			}
		});
	}, { threshold: 0.1 });
	revealEls.forEach(el => revealObserver.observe(el));
 
	// ── Hero image: release zoom on load ──────────────────────
	// NEW — the hero image starts scaled to 1.06 via CSS and
	// transitions to scale(1) once loaded, creating a subtle
	// zoom-out entrance.
	const heroImg = document.querySelector('.hero__img-panel img') as HTMLImageElement;
	if (heroImg) {
		const release = () => { heroImg.style.transform = 'scale(1)'; };
		if (heroImg.complete) { release(); } else { heroImg.addEventListener('load', release); }
	}
</script>
