---
import IndexPage from "../../layouts/IndexPage.astro";
import { getCollection } from "astro:content";

const studies = (await getCollection("case-studies", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<IndexPage
  title="Case Studies | Be Hosted"
  description="Explore our case studies and see how we help brands create beautiful, elevated experiences."
  heading="Case Studies"
>
  {studies.length === 0 && <p>No case studies yet — check back soon.</p>}
  <ul class="index-list">
    {studies.map((study) => (
      <li class={`index-card${study.data.heroImage ? " index-card--with-image" : ""}`}>
        {study.data.heroImage && (
          <img class="index-card__thumbnail" src={study.data.heroImage} alt={study.data.brandName ?? study.data.title} loading="lazy" />
        )}
        <div class="index-card__content">
          <h2 class="index-card__title">{study.data.brandName ?? study.data.title}</h2>
          {study.data.subtitle && <p class="index-card__subtitle">{study.data.subtitle}</p>}
          <p class="index-card__date">
            {study.data.publishDate.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}
          </p>
          <p class="index-card__description">{study.data.description}</p>
          <a class="link" href={`/case-studies/${study.id}/`}>Read the case study &#x2192;</a>
        </div>
      </li>
    ))}
  </ul>
</IndexPage>
