---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Article.astro";

export async function getStaticPaths() {
  const caseStudies = await getCollection(
    "case-studies",
    ({ data }) => !data.draft
  );

  return caseStudies.map((study) => ({
    params: {
      slug: study.id,
    },
    props: {
      study,
    },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);
const { title, description, heroImage, brandName, subtitle, canonical, showHeroOnPage } = study.data;
---

<Layout title={title} description={description} frontmatter={{ canonical }}>
  <main class="page__wrapper">
    <article class="post">
      <header class="post__header">
        <h1 class="heading">{brandName ?? title}</h1>
        {subtitle && <p class="sub-heading">{subtitle}</p>}
      </header>

      {heroImage && showHeroOnPage !== false && (
        <img
          class="post__hero"
          src={heroImage}
          alt={brandName ?? title}
          loading="eager"
        />
      )}

      <Content />

      <section class="post-section">
        <div id="cta-container">
          <div><h2 class="cta-heading">Ready to create something beautiful?</h2></div>
          <div><p class="cta-tagline">Whether you need content that converts or a table that wows, we've got you.</p></div>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSeo4LEToHuBtsB65ZMBN8lZC6Y_CBEOvMHgDi5xAZGMaWgpIg/viewform?usp=header" target="_blank">
            <button class="cta-button">Yes, absolutely!</button>
          </a>
        </div>
      </section>
    </article>
  </main>
</Layout>
