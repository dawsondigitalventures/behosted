---
import "../styles/base.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const {
  title = "Be Hosted",
  description = "Tablescaping & Social Content Creation"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <meta
      name="description"
      content={description}
    />

    <meta
      name="generator"
      content={Astro.generator}
    />

    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" />

    <!-- Swiper CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css"
    />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HX0PB4WL48"></script>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        dataLayer.push(arguments);
      }

      gtag('js', new Date());
      gtag('config', 'G-HX0PB4WL48');
    </script>
  </head>

  <body>
    <Header />
    <slot />

     <Footer />

    <!-- Swiper JS -->
    <script
      src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"
      defer
    ></script>

    <!-- Your JS -->
    <script is:inline src="/js/core.js"></script>
  </body>
</html>